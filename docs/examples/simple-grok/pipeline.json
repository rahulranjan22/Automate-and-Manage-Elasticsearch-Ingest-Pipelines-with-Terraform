{
  "description": "Parse NGINX access logs with grok and set @timestamp",
  "processors": [
    {
      "grok": {
        "field": "message",
        "patterns": ["%{NGINXACCESS}"]
      }
    },
    {
      "date": {
        "field": "timestamp",
        "formats": ["dd/MMM/yyyy:H:m:s Z"]
      }
    }
  ]
}

